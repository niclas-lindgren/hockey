#!/usr/bin/env bash
# rvv-miniputt-checkpoint — pretty-print a pipeline stage checkpoint.
#
# Usage:
#   scripts/rvv-miniputt-checkpoint <stage> [--work-dir .pipeline]
#
# Arguments:
#   stage       Stage name or number: 1-4, stage1-stage4, config, scraping, planning, export
#
# Options:
#   --work-dir  Pipeline work directory (default: .pipeline)
#
# Examples:
#   scripts/rvv-miniputt-checkpoint stage1
#   scripts/rvv-miniputt-checkpoint 3 --work-dir /tmp/pipeline
set -euo pipefail

ROOT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
PYTHON_BIN="$ROOT_DIR/venv/bin/python3"

if [[ -x "$PYTHON_BIN" ]]; then
  exec "$PYTHON_BIN" -m tournament_scheduler.cli.checkpoint_printer "$@"
fi

exec python3 -m tournament_scheduler.cli.checkpoint_printer "$@"
